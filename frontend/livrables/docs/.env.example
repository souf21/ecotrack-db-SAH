# ================================
# EcoTrack API — Variables d'environnement
# ================================

# Environnement
NODE_ENV=development

# Serveur
PORT=5000

# Supabase
SUPABASE_URL=https://votre-projet.supabase.co
SUPABASE_ANON_KEY=clé_anon_supabase

# JWT (généré automatiquement par Supabase)
JWT_SECRET=secret_jwt_256_bits_minimum

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379